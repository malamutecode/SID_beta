# Frontend env (Vite). Copy to `.env` to override.

# Base URL of the FastAPI backend.
# - Local dev (npm run dev): http://localhost:8000 (direct to uvicorn).
# - Docker/nginx: /api (relative; nginx proxies /api -> backend). Set by the
#   frontend Dockerfile build arg, so you don't need it here for Docker.
VITE_API_BASE_URL=http://localhost:8000

# Demo flag fallback used only if the backend /config is unreachable. The
# backend's DEMO_ENV (reported via /config) takes precedence when available.
VITE_DEMO_ENV=true
