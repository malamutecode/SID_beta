# Copy to `.env` and adjust. All values are optional; defaults shown below.
# This single root `.env` is read by BOTH the classifier core (SID_* settings,
# src/sid_beta/config.py) and the demo backend (DEMO_ENV + CORS,
# backend/app/config.py). Run uvicorn from the project root so it resolves here.
# Real environment variables take precedence over this file.

# ── Classifier core (SID_* — src/sid_beta/config.py) ────────────────────────

# LM Studio's OpenAI-compatible endpoint (default local server).
SID_BASE_URL=http://localhost:1234/v1

# The model identifier as shown in LM Studio. Must be a vision-language model
# (e.g. Qwen3-VL / Gemma 3) for image / scanned-PDF input to work.
SID_MODEL_NAME=qwen/qwen3-vl-8b

# LM Studio does not require a real key; any placeholder works.
SID_API_KEY=lm-studio

# A PDF page with fewer extracted characters than this is treated as scanned
# (rasterized and sent to the vision model).
SID_PDF_TEXT_MIN_CHARS=20

# Path to Poppler's bin dir (folder with pdftoppm). Needed for scanned PDFs when
# Poppler is not on PATH. Leave empty to rely on PATH.
# Example (winget install): C:\Users\<you>\AppData\Local\Microsoft\WinGet\Packages\oschwartz10612.Poppler_Microsoft.Winget.Source_8wekyb3d8bbwe\poppler-<version>\Library\bin
SID_POPPLER_PATH=

# DPI for rasterizing scanned PDF pages. Lower = fewer vision tokens (helps fit
# small context windows), still legible for OCR.
SID_PDF_RENDER_DPI=120

# Max characters of extracted text sent per document (0 = no cap). Keeps requests
# within small local context windows; a classifier only needs an excerpt.
SID_MAX_TEXT_CHARS=6000

# ── Demo backend (backend/app/config.py) ────────────────────────────────────
# Read once at backend startup; restart uvicorn after changing (--reload does
# not re-read env vars). The frontend reads the demo flag from /config on load.

# Demo mode: when true, /config reports demo_env=true and the app runs the fixed
# end-to-end scenario (4 sample docs, deterministic doc->employee assignment,
# preloaded mock diagram). Bare name (no SID_ prefix). Default: false.
DEMO_ENV=false

# Comma-separated CORS origins allowed to call the API. Defaults already cover
# localhost / 127.0.0.1 on Vite ports 5173-5175; override only if needed.
# SID_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
